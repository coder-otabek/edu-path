{% load static %}{% autoescape off %}{
  "name": "{{ site.name|default:'EduPath' }}",
  "short_name": "{{ site.short_name|default:'EduPath' }}",
  "description": "{{ site.meta_description|default:'O\u2019z imkoniyatlaringni bil, universitetingni top' }}",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#F8FAFF",
  "theme_color": "#2563EB",
  "orientation": "portrait-primary",
  "icons": [
    {% if site.favicon %}{
      "src": "{{ site.favicon.url }}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    }{% else %}{
      "src": "{% static 'img/icon-192.png' %}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    }, {
      "src": "{% static 'img/icon-512.png' %}",
      "sizes": "512x512",
      "type": "image/png"
    }{% endif %}
  ],
  "categories": ["education"],
  "lang": "uz"
}{% endautoescape %}
