# ============================================
# EduPath — .env.example
# Nusxa oling: cp .env.example .env
# Keyin qiymatlarni o'zgartiring
# ============================================

# ─── Django ──────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-here

# Vergul bilan ajrating, bo'shliq bo'lmasin
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Email havolalar uchun
SITE_URL=http://localhost:8000

# ─── Database ────────────────────────────────
# SQLite (lokal) yoki PostgreSQL (VPS)
USE_SQLITE=True

# PostgreSQL (USE_SQLITE=False bo'lsa ishlaydi)
DB_NAME=edupath_db
DB_USER=edupath_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── Gmail SMTP ──────────────────────────────
# App Password olish:
# myaccount.google.com -> Security -> 2-Step Verification -> App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=EduPath <yourgmail@gmail.com>

# ─── Security ────────────────────────────────
SECURE_SSL_REDIRECT=False